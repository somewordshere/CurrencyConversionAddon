{
  "name": "currency-converter-pro-extension",
  "version": "1.6.0",
  "private": true,
  "description": "Privacy-focused Manifest V3 currency conversion extension",
  "scripts": {
    "test": "node --test",
    "prepare:chrome": "node scripts/build.mjs chrome --prepare-only",
    "prepare:firefox": "node scripts/build.mjs firefox --prepare-only",
    "build": "node scripts/build.mjs all",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "lint:firefox": "npm run prepare:firefox && web-ext lint --source-dir dist/firefox",
    "run:firefox": "npm run prepare:firefox && web-ext run --source-dir dist/firefox",
    "test:browser": "npm run prepare:chrome && playwright test",
    "test:browser:headed": "npm run prepare:chrome && playwright test --headed",
    "check": "node scripts/check-project.js",
    "verify": "npm run check && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "web-ext": "9.4.0"
  }
}
